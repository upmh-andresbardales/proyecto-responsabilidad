# ============================================
# Sistema de Monitoreo Acuapónico - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=acuaponia2026
MONGO_INITDB_DATABASE=acuaponia
MONGO_URI=mongodb://admin:acuaponia2026@mongo:27017/acuaponia?authSource=admin

# --- EMQX (Broker MQTT) ---
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=public
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_WS_PORT=8084

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://frontend:80

# --- Sistema Acuapónico ---
SYSTEM_ID=sistema-01
MQTT_BASE_TOPIC=acuaponia
SENSOR_PUBLISH_INTERVAL=5
